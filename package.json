{
  "name": "swarm-cp",
  "version": "0.0.1",
  "private": true,
  "description": "Claude-native swarm orchestration control plane (MVP skeleton)",
  "type": "module",
  "bin": {
    "swarm": "./dist/cli.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "doctor": "node dist/cli.js doctor",
    "eval:regression": "node dist/cli.js eval eval-suites/regression.yaml --swarm-cli \"node dist/cli.js\""
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "commander": "^12.1.0",
    "execa": "^9.5.0",
    "p-queue": "^8.0.1",
    "simple-git": "^3.27.0",
    "yaml": "^2.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  }
}
